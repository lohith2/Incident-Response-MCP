# Python workflow sidecar
FROM python:3.11-slim

# Security: non-root user
RUN groupadd -r workflow && useradd -r -g workflow workflow

WORKDIR /app

# Install dependencies before copying source (layer cache)
COPY workflow/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY workflow/ ./workflow/

USER workflow

EXPOSE 8000

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

CMD ["uvicorn", "workflow.main:app", "--host", "0.0.0.0", "--port", "8000"]
